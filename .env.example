# Shopify app credentials (populated by `shopify app config link`)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_orders,write_orders,read_customers
SHOPIFY_APP_URL=

# Database (SQLite for dev)
DATABASE_URL="file:dev.sqlite"

# Encryption key for merchant Payram API keys stored in DB.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes).
# Store securely; rotate via re-encryption migration.
ENCRYPTION_KEY=

# Optional dev shortcut: set these to skip the Settings page.
# In production / multi-tenant use, credentials are stored per-shop in the DB via the Settings page.
PAYRAM_BASE_URL=
PAYRAM_PROJECT_API_KEY=
